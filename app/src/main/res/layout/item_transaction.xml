<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="16dp"
    android:background="@drawable/tuile_categorie"
    android:gravity="center_vertical"
    android:elevation="2dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/texteDateTransaction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aujourd'hui - 14:30"
            android:textColor="@color/texte_fonce"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/texteIdTransaction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#TRX-001"
            android:textColor="#757575"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/texteTotalTransaction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="14.20 $"
        android:textColor="@color/texte_fonce"
        android:textSize="22sp"
        android:textStyle="bold" />

</LinearLayout>